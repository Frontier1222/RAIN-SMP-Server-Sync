{
	"format_version" : "1.10.0",
	"animation_controllers" : {
		"controller.animation.wolf.sitting" : {
			"initial_state" : "default",
			"states" : {
				"default" : {
					"animations" : [ "wolf_leg_default" ],
					"transitions" : [
						{
							"sitting" : "query.is_sitting || (query.has_property('viberater:sitting') && query.property('viberater:sitting'))"
						}
					]
				},
				"sitting" : {
					"animations" : [ "wolf_sitting" ],
					"transitions" : [
						{
							"default" : "!query.is_sitting && !(query.has_property('viberater:sitting') && query.property('viberater:sitting'))"
						}
					]
				}
			}
        }
	}
}
