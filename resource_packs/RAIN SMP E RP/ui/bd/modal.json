{
    "namespace": "bd_modal", 

    "root_panel": {
        "type": "image",
        "texture": "textures/ui/Black",
        "alpha": 0.3,
        "size": ["100%","100%"],
        "controls": [
            {
                "base_panel": {
                    "type": "stack_panel",
                    "size": [300, 180],
                    "layer": 1,
                    "controls": [
                        {
                            "header": {
                                "type": "panel",
                                "size": ["100%", 20],
                                "controls": [
                                    {
                                        "title": {
                                            "type": "label",
                                            "text": "#text",
                                            "anchor_from": "left_middle",
                                            "anchor_to": "left_middle",
                                            "font_scale_factor": 1.4,
                                            "shadow": true,
                                            "layer": 1,
                                            "text_alignment": "left",
                                            "bindings": [
                                                {
                                                    "binding_name": "#title_text"
                                                },
                                                {
                                                    "binding_type": "view",
                                                    "source_property_name": "(#title_text - $modal)",
                                                    "target_property_name": "#text"
                                                }
                                            ]
                                            }
                                    },
                                    {
                                        "close@close_btn": {}
                                    }
                                ]
                            }
                        },
                        {
                            "body": {
                                "type": "panel",
                                "size": ["100%", "fill"],
                                "controls": [
                                    {
                                        "bg": {
                                            "type": "image",
                                            "size": ["100%", "100%"],
                                            "texture": "textures/bd/bg",
                                            "fill": true,
                                            "layer": -1,
                                            "controls": [
                                                {
                                                    "bar": {
                                                        "type": "image",
                                                        "texture": "textures/ui/White",
                                                        "color": [0.3059, 0.1922, 0.4118],
                                                        "anchor_from": "top_left",
                                                        "anchor_to": "top_left",
                                                        "size": ["100%", 3],
                                                        "layer": 2
                                                    }
                                                },
                                                {
                                                    "content@content": {}
                                                }
                                            ]
                                        }
                                    }
                                ]
                            }
                        }
                    ]
                }
            }
        ],
        "bindings": [
            {
                "binding_name": "#title_text"
            },
            {
                "binding_type": "view",
                "source_property_name": "(not (#title_text - $modal = #title_text))",
                "target_property_name": "#visible"
            }
        ]
    },

   "content": {
        "type": "panel",
        "size": [ "98%", "90%" ],
        "controls": [
            {
                "custom_form_panel@common.scrolling_panel" : {
                    "anchor_to": "top_left",
                    "anchor_from": "top_left",
                    "$show_background": false,
                    "size": [ "100%", "100%" ],
                    "$scrolling_content": "bd_modal.scrolling_content",
                    "$scroll_size": [ 5, "100% - 4px" ],
                    "$scrolling_pane_size": [ "100% - 4px", "100% - 2px" ],
                    "$scrolling_pane_offset": [ 2, 0 ],
                    "$scroll_bar_right_padding_size": [ 0, 0 ]
                }
            }
        ]
    },

    "scrolling_content": {
    "type": "stack_panel",
    "size": ["100% - 4px", "100%c"],
    "offset": [2,0],
    "orientation": "vertical",
    "anchor_from": "top_left",
    "anchor_to": "top_left",
    "controls": [
      {
        "generated_form@server_form.generated_contents": {}
      },
      {
        "submit@btntemp": {}
      }
    ]    
  },

    "btntemp": {
        "type": "button",
        "size": ["100%", 32 ],
        "controls": [
            {
                "default@btnvis": {
                     "$texture": "textures/bd/btn_default"
                }
            },
            {
                "hover@btnvis": {
                     "$texture": "textures/bd/btn_pressed"
                }
            },
            {
                "pressed@btnvis": {
                    "$texture": "textures/bd/btn_pressed"
                }
            }
        ],
        "default_control": "default",
        "hover_control": "hover",
        "pressed_control": "pressed",
        "sound_name": "random.click",
        "sound_volume": 1,
        "sound_pitch": 1,
        "focus_enabled": true,
        "focus_wrap_enabled": false,
        "button_mappings": [
            {
                "from_button_id": "button.menu_select",
                "to_button_id": "button.submit_custom_form",
                "mapping_type": "pressed"
            },
            {
                "from_button_id": "button.menu_ok",
                "to_button_id": "button.submit_custom_form",
                "mapping_type": "focused"
            }
        ],
        "bindings": [
            {
              "binding_name": "#submit_button_visible",
              "binding_name_override": "#visible"
            }
          ]
    },

    "btnvis": {
        "type": "image",
        "texture": "$texture",
        "alpha": 0.7,
        "size": ["100%", "100%"],
        "layer": -1,
        "controls": [
            {
                "text": {
                    "type": "label",
                    "text": "#submit_text",
                    "layer": 1,
                    "text_alignment": "center",
                    "shadow": true,
                    "bindings": [
                        {
                            "binding_type": "global",
                            "binding_condition": "once",
                            "binding_name": "#submit_text"
                        }
                    ]
                }
            }
        ]
    },

    "close_btn": {
        "type": "button",
        "size": [ 12, 12 ],
        "anchor_from": "bottom_right",
        "anchor_to": "bottom_right",
        "offset": [0,-2],
        "controls": [
           {
            "default@tipvis": {}
           },
                {
                "hover@tipvis": {}
            },
                {
                "pressed@tipvis": {}
            }
        ],
        "default_control": "default",
        "hover_control": "hover",
        "pressed_control": "pressed",
        "sound_name": "random.click",
        "sound_volume": 1,
        "sound_pitch": 1,
        "focus_enabled": true,
        "focus_wrap_enabled": false,
        "button_mappings": [
            {
                "from_button_id": "button.menu_select",
                "to_button_id": "button.menu_exit",
                "mapping_type": "pressed"
            },
            {
                "from_button_id": "button.menu_ok",
                "to_button_id": "button.menu_exit",
                "mapping_type": "focused"
            }
        ]
    },

    "tipvis": {
        "type": "image",
        "texture": "textures/ui/hud_tip_text_background",
        "size": ["100%", "100%"],
        "alpha": 0.6,
        "layer": -1,
        "controls": [
            {
                "icon": {
                    "type": "image",
                    "texture": "$icon",
                    "$icon|default": "textures/ui/close_button_default_light",
                    "size": ["80%", "80%"],
                    "layer": 1
                }
            }
        ]
    }
}