{
    "namespace": "bd_sub", 

    "root_panel": {
        "type": "image",
        "texture": "textures/ui/Black",
        "alpha": 0.3,
        "size": ["100%","100%"],
        "controls": [
            {
                "base_panel": {
                    "type": "stack_panel",
                    "size": [350, 230],
                    "layer": 1,
                    "controls": [
                        {
                            "header": {
                                "type": "panel",
                                "size": ["100%", 20],
                                "controls": [
                                    {
                                        "title": {
                                            "type": "label",
                                            "text": "#text",
                                            "anchor_from": "left_middle",
                                            "anchor_to": "left_middle",
                                            "font_scale_factor": 1.4,
                                            "shadow": true,
                                            "layer": 1,
                                            "text_alignment": "left",
                                            "bindings": [
                                                {
                                                    "binding_name": "#title_text"
                                                },
                                                {
                                                    "binding_type": "view",
                                                    "source_property_name": "(#title_text - $sub)",
                                                    "target_property_name": "#text"
                                                }
                                            ]
                                            }
                                    },
                                    {
                                        "close@close_btn": {}
                                    }
                                ]
                            }
                        },
                        {
                            "body": {
                                "type": "panel",
                                "size": ["100%", "fill"],
                                "controls": [
                                    {
                                        "bg": {
                                            "type": "image",
                                            "size": ["100%", "100%"],
                                            "texture": "textures/bd/bg",
                                            "fill": true,
                                            "layer": -1,
                                            "controls": [
                                                {
                                                    "black": {
                                                        "type": "image",
                                                        "texture": "textures/ui/Black",
                                                        "size": ["100%", "100%"],
                                                        "fill": true,
                                                        "alpha": 0.3,
                                                        "layer": 1
                                                    }
                                                },
                                                {
                                                    "bar": {
                                                        "type": "image",
                                                        "texture": "textures/ui/White",
                                                        "color": [0.3059, 0.1922, 0.4118],
                                                        "anchor_from": "top_left",
                                                        "anchor_to": "top_left",
                                                        "size": ["100%", 3],
                                                        "layer": 2
                                                    }
                                                },
                                                {
                                                    "content@content": {}
                                                }
                                            ]
                                        }
                                    }
                                ]
                            }
                        }
                    ]
                }
            }
        ],
        "bindings": [
            {
                "binding_name": "#title_text"
            },
            {
                "binding_type": "view",
                "source_property_name": "(not (#title_text - $sub = #title_text))",
                "target_property_name": "#visible"
            }
        ]
    },

    "content": {
        "type": "stack_panel",
        "size": ["100%-12px", "100%-18px"],
        "layer": 10,
        "orientation": "horizontal",
        "collection_name": "form_buttons",
        "controls": [
            {
                "b1@button_panel": {
                    "size": ["fill", "100%"],
                    "collection_index": 0
                }
            },
            {
                "div": {
                    "type": "panel",
                    "size": [6,6]
                }
            },
            {
                "b2@button_panel": {
                    "size": ["fill", "100%"],
                    "collection_index": 1
                }
            },
            {
                "div": {
                    "type": "panel",
                    "size": [6,6]
                }
            },
            {
                "b3@button_panel": {
                    "size": ["fill", "100%"],
                    "collection_index": 2
                }
            }
        ]
    },

  "button_panel": {
      "type": "panel",
      "controls": [
        {
        "button@common.button": {
            "$pressed_button_name": "button.form_button_click",
            "controls": [
            {
                "default@bd_sub.button_parts": {
                "$texture": "textures/bd/btnc_default"
                }
            },
            {
                "hover@bd_sub.button_parts_hover": {
                  "$texture": "textures/bd/btnc_pressed",
                  "$offset": [0, 0],
                  "$bindings": [
                      {
                      "binding_name": "#form_button_text",
                      "binding_name_override": "#hover_text",
                      "binding_collection_name": "form_buttons",
                      "binding_type": "collection"
                      },
                      {
                      "binding_type": "collection",
                      "binding_collection_name": "form_buttons",
                      "binding_name": "#form_button_text"
                      }
                  ]
               }
          }
          ],
          "bindings": [
          {
              "binding_type": "collection_details",
              "binding_collection_name": "form_buttons"
          }]
        }
    }]
  },

  "button_parts": {
    "type": "panel",
    "$bindings|default": [],
    "$offset|default": [0, 0],
    "controls": [
      {
        "button_image": {
          "layer": 2,
          "type": "image",
          "texture": "$texture"
        }
      },
      {
        "button_icon": {
          "type": "image",
          "layer": 5,
          "size": [40,40],
          "offset": [0,-5],
          "bindings": [
            {
              "binding_name": "#form_button_texture",
              "binding_name_override": "#texture",
              "binding_type": "collection",
              "binding_collection_name": "form_buttons"
            },
            {
              "binding_name": "#form_button_texture_file_system",
              "binding_name_override": "#texture_file_system",
              "binding_type": "collection",
              "binding_collection_name": "form_buttons"
            }
          ]
        }
      },
      {
        "button_text": {
            "type": "label",
            "text": "#form_button_text",
            "layer": 10,
            "font_scale_factor": 1.2,
            "offset": [0,-5],
            "anchor_from": "bottom_middle",
            "anchor_to": "bottom_middle",
            "bindings": [
              {
                  "binding_name": "#form_button_text",
                  "binding_collection_name": "form_buttons",
                  "binding_type": "collection"
              }
            ]
        }
      }
    ]
  },
  "button_parts_hover": {
    "type": "panel",
    "$bindings|default": [],
    "$offset|default": [0, 0],
    "controls": [
      {
        "button_image": {
          "layer": 2,
          "type": "image",
          "texture": "$texture",
          "offset": [0, -1]
        }
      },
      {
        "button_icon": {
          "type": "image",
          "layer": 10,
          "offset": [0, -5],
          "size": [40,40],
          "bindings": [
            {
              "binding_name": "#form_button_texture",
              "binding_name_override": "#texture",
              "binding_type": "collection",
              "binding_collection_name": "form_buttons"
            },
            {
              "binding_name": "#form_button_texture_file_system",
              "binding_name_override": "#texture_file_system",
              "binding_type": "collection",
              "binding_collection_name": "form_buttons"
            }
          ]
        }
      },
      {
        "button_text": {
            "type": "label",
            "text": "#form_button_text",
            "layer": 10,
            "font_scale_factor": 1.2,
            "offset": [0,-5],
            "anchor_from": "bottom_middle",
            "anchor_to": "bottom_middle",
            "bindings": [
              {
                  "binding_name": "#form_button_text",
                  "binding_collection_name": "form_buttons",
                  "binding_type": "collection"
              }
            ]
        }
      }
    ]
  },


   "close_btn": {
        "type": "button",
        "size": [ 12, 12 ],
        "anchor_from": "bottom_right",
        "anchor_to": "bottom_right",
        "offset": [0,-2],
        "controls": [
           {
            "default@tipvis": {}
           },
                {
                "hover@tipvis": {}
            },
                {
                "pressed@tipvis": {}
            }
        ],
        "default_control": "default",
        "hover_control": "hover",
        "pressed_control": "pressed",
        "sound_name": "random.click",
        "sound_volume": 1,
        "sound_pitch": 1,
        "focus_enabled": true,
        "focus_wrap_enabled": false,
        "button_mappings": [
            {
                "from_button_id": "button.menu_select",
                "to_button_id": "button.menu_exit",
                "mapping_type": "pressed"
            },
            {
                "from_button_id": "button.menu_ok",
                "to_button_id": "button.menu_exit",
                "mapping_type": "focused"
            }
        ]
    },

    "tipvis": {
        "type": "image",
        "texture": "textures/ui/hud_tip_text_background",
        "size": ["100%", "100%"],
        "alpha": 0.6,
        "layer": -1,
        "controls": [
            {
                "icon": {
                    "type": "image",
                    "texture": "$icon",
                    "$icon|default": "textures/ui/close_button_default_light",
                    "size": ["80%", "80%"],
                    "layer": 1
                }
            }
        ]
    }
    
}