

{
	"format_version": "1.10.0",
	"particle_effect": {
		"description": {
			"identifier": "ulkd_ess:anchor",
			"basic_render_parameters": {
				"material": "particles_blend",
				"texture": "textures/unlinked/essentials/white"
			}
		},
		"curves": {
			"variable.fade": {
				"type": "linear",
				"input": "v.particle_age",
				"horizontal_range": "v.particle_lifetime",
				"nodes": [0, 0.6, 0.56, 0.5, 0.44, 0.38, 0.31, 0.24, 0.16, 0.1, 0.04, 0, 0]
			}
		},
		"events": {
			"next_face": {
				"sequence": [
					{
						"expression": "t.face = v.face + 1;t.offset_x = v.offset_x;t.offset_y = v.offset_y;t.offset_z = v.offset_z;t.size = v.size;"
					},
					{
						"particle_effect": {
							"effect": "ulkd_ess:anchor",
							"type": "particle",
							"pre_effect_expression": "v.face = t.face;v.offset_x = t.offset_x;v.offset_y = t.offset_y;v.offset_z = t.offset_z;v.size = t.size;"
						}
					}
				]
			}
		},
		"components": {
			"minecraft:emitter_initialization": {
				"creation_expression": "v.offset_x = v.offset_x ?? 0;v.offset_y = v.offset_y ?? 0;v.offset_z = v.offset_z ?? 0;v.face = v.face ?? 0;v.size = v.size ?? 0.49;",
				"per_update_expression": "v.angle = v.face == 1 ? 90 : v.face == 2 ? 270 : v.face == 6 ? 180 : 0;v.is_vertical = v.face == 3 || v.face == 4;v.size = v.size ?? 0.49;"
			},
			"minecraft:emitter_rate_instant": {
				"num_particles": "v.face > 6 ? 0 : 1"
			},
			"minecraft:emitter_lifetime_once": {
				"active_time": 1
			},
			"minecraft:emitter_shape_point": {},
			"minecraft:particle_lifetime_expression": {
				"max_lifetime": 20
			},
			"minecraft:particle_lifetime_events": {
				"timeline": {
					"0.0": "next_face"
				}
			},
			"minecraft:particle_motion_parametric": {
				"relative_position": [
					"(v.is_vertical ? 0 : math.sin(v.angle) * v.size) + v.offset_x", 
					"((v.face == 3 ? 1 : v.face == 4 ? -1 : 0) * v.size) + v.offset_y", 
					"(v.is_vertical ? 0 : math.cos(v.angle) * v.size) + v.offset_z"
				]
			},
			"minecraft:particle_appearance_billboard": {
				"size": ["v.face == 0 ? 0.001 : v.size", "v.face == 0 ? 0.001 : v.size"],
				"facing_camera_mode": "direction_z",
				"direction": {
					"mode": "custom",
					"custom_direction": [
						"v.is_vertical ? 0 : math.sin(v.angle)", 
						"v.face == 3 ? 1 : v.face == 4 ? -1 : 0", 
						"v.is_vertical ? 0 : math.cos(v.angle)"
					]
				},
				"uv": {
					"texture_width": 16,
					"texture_height": 16,
					"uv": [0, 0],
					"uv_size": [1, 1]
				}
			},
			"minecraft:particle_appearance_tinting": {
				"color": [0, 1, 0.9, "variable.fade"]
			}
		}
	}
}