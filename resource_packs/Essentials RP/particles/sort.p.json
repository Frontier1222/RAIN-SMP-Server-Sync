				"size": ["0.1 + v.particle_random_1 * 0.1", "0.1 + v.particle_random_1 * 0.1"],
				"facing_camera_mode": "rotate_xyz"
			},
			"minecraft:particle_appearance_tinting": {
				"color": {
					"interpolant": "v.particle_age / v.particle_lifetime",
					"gradient": {
						"0.0": "#0000FFCB",
						"0.1": "#FF00FFCB",
						"0.81": "#FF00FFCB",
						"1.0": "#0000FFCB"
					}
