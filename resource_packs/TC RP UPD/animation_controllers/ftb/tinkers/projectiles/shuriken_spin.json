{
	"format_version": "1.10.0",
	"animation_controllers": {
	  "controller.animation.ftb_tc.ftb_tc_shuriken_spin": {
		"states": {
		  "stop": {
			"animations": [
			  "stop"
			],
			"transitions": [
			  {
				"spin": "query.modified_move_speed > 0.1"
			  }
			],
			"blend_transition": 0.5
		  },
		  "spin": {
			"animations": [
			  "spin"
			],
			"transitions": [
			  {
				"stop": "query.modified_move_speed <= 0.1"
			  }
			],
			"blend_transition": 0.2
		  }
		}
	  }
	}
  }