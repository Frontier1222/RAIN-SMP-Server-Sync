{
  "format_version": "1.8.0",
  "render_controllers": {
    "controller.render.ftb_tc.bow": {
      "geometry": "array.bow_geo_frames[v.charge_amount]",
      "materials": [ { "*": "v.is_enchanted ? material.enchanted : material.default" } ],
      "arrays": {
        "geometries": {
          "array.bow_geo_frames": [
            "geometry.bow_standby",
            "geometry.bow_pulling_0",
            "geometry.bow_pulling_1",
            "geometry.bow_pulling_2"
          ]
        },
        "textures": {
          "array.bow_texture_frames": [
            "texture.bow_standby",
            "texture.bow_pulling_0",
            "texture.bow_pulling_1",
            "texture.bow_pulling_2"
          ]
        }
      },
      "textures": [ "array.bow_texture_frames[v.charge_amount]", "texture.enchanted" ]
    }
  }
}