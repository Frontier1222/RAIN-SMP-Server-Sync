{
    "namespace": "bd_main", 
    
    "root_panel": {
        "type": "image",
        "texture": "textures/ui/Black",
        "alpha": 0.3,
        "size": ["100%","100%"],
        "controls": [
            {
                "base_panel": {
                    "type": "stack_panel",
                    "size": [350, 230],
                    "layer": 1,
                    "controls": [
                        {
                            "header": {
                                "type": "panel",
                                "size": ["100%", 20],
                                "controls": [
                                    {
                                        "title": {
                                            "type": "label",
                                            "text": "#text",
                                            "anchor_from": "left_middle",
                                            "anchor_to": "left_middle",
                                            "font_scale_factor": 1.4,
                                            "shadow": true,
                                            "layer": 1,
                                            "text_alignment": "left",
                                            "bindings": [
                                                {
                                                    "binding_name": "#title_text"
                                                },
                                                {
                                                    "binding_type": "view",
                                                    "source_property_name": "((#title_text - $main) - $main_legacy)",
                                                    "target_property_name": "#text"
                                                }
                                            ]
                                        }
                                    },
                                    {
                                        "close@close_btn": {}
                                    }
                                ]
                            }
                        },
                        {
                            "body": {
                                "type": "panel",
                                "size": ["100%", "fill"],
                                "controls": [
                                    {
                                        "bg": {
                                            "type": "image",
                                            "size": ["100%", "100%"],
                                            "texture": "textures/bd/bg",
                                            "fill": true,
                                            "layer": -1,
                                            "controls": [
                                                {
                                                    "black": {
                                                        "type": "image",
                                                        "texture": "textures/ui/Black",
                                                        "size": ["100%", "100%"],
                                                        "fill": true,
                                                        "alpha": 0.3,
                                                        "layer": 1
                                                    }
                                                },
                                                {
                                                    "bar": {
                                                        "type": "image",
                                                        "texture": "textures/ui/White",
                                                        "color": [0.3059, 0.1922, 0.4118],
                                                        "anchor_from": "top_left",
                                                        "anchor_to": "top_left",
                                                        "size": ["100%", 3],
                                                        "layer": 2
                                                    }
                                                },
                                                {
                                                    "simple_scroll_panel@bd_main.simple_scroll_panel": {}
                                                }
                                            ]
                                        }
                                    }
                                ]
                            }
                        }
                    ]
                }
            }
        ],
        "bindings": [
            {
                "binding_name": "#title_text"
            },
            {
                "binding_type": "view",
                "source_property_name": "(not ((#title_text - $main) = #title_text) or not ((#title_text - $main_legacy) = #title_text))",
                "target_property_name": "#visible"
            }
        ]
    },

    "content": {
        "type": "stack_panel",
        "size": ["98%", "90%"],
        "layer": 10,
        "controls": [
          {
        "scrolling_panel@common.scrolling_panel": {
          "anchor_to": "top_left",
          "anchor_from": "top_left",
          "$show_background": false,
          "size": [ "100%", "100%" ],
          "$scrolling_content": "bd_action.scrolling_content",
          "$scroll_size": [ 5, "100% - 4px" ],
          "$scrolling_pane_size": [ "100% - 4px", "100% - 2px" ],
          "$scrolling_pane_offset": [ 2, 0 ],
          "$scroll_bar_right_padding_size": [ 0, 0 ]
            }
          }
        ]
    },

  "button_panel": {
      "type": "panel",
      "controls": [
        {
        "button@common.button": {
            "$pressed_button_name": "button.form_button_click",
            "controls": [
            {
                "default@bd_main.button_parts": {
                "$texture": "textures/bd/btnc_default"
                }
            },
            {
                "hover@bd_main.button_parts_hover": {
                  "$texture": "textures/bd/btnc_pressed",
                  "$offset": [0, 0],
                  "$bindings": [
                      {
                      "binding_name": "#form_button_text",
                      "binding_name_override": "#hover_text",
                      "binding_collection_name": "form_buttons",
                      "binding_type": "collection"
                      },
                      {
                      "binding_type": "collection",
                      "binding_collection_name": "form_buttons",
                      "binding_name": "#form_button_text"
                      }
                  ]
               }
          }
          ],
          "bindings": [
          {
              "binding_type": "collection_details",
              "binding_collection_name": "form_buttons"
          }]
        }
    }]
  },

  "button_parts": {
    "type": "panel",
    "$bindings|default": [],
    "$offset|default": [0, 0],
    "controls": [
      {
        "button_image": {
          "layer": 2,
          "type": "image",
          "texture": "$texture"
        }
      },
      {
        "button_icon": {
          "type": "image",
          "layer": 5,
          "size": [40,40],
          "offset": [0,-5],
          "bindings": [
            {
              "binding_name": "#form_button_texture",
              "binding_name_override": "#texture",
              "binding_type": "collection",
              "binding_collection_name": "form_buttons"
            },
            {
              "binding_name": "#form_button_texture_file_system",
              "binding_name_override": "#texture_file_system",
              "binding_type": "collection",
              "binding_collection_name": "form_buttons"
            }
          ]
        }
      },
      {
        "button_text": {
            "type": "label",
            "text": "#form_button_text",
            "layer": 10,
            "font_scale_factor": 1.2,
            "offset": [0,-8],
            "anchor_from": "bottom_middle",
            "anchor_to": "bottom_middle",
            "bindings": [
              {
                  "binding_name": "#form_button_text",
                  "binding_collection_name": "form_buttons",
                  "binding_type": "collection"
              }
            ]
        }
      }
    ]
  },
  "button_parts_hover": {
    "type": "panel",
    "$bindings|default": [],
    "$offset|default": [0, 0],
    "controls": [
      {
        "button_image": {
          "layer": 2,
          "type": "image",
          "texture": "$texture",
          "offset": [0, -1]
        }
      },
      {
        "button_icon": {
          "type": "image",
          "layer": 10,
          "offset": [0, -6],
          "size": [40,40],
          "bindings": [
            {
              "binding_name": "#form_button_texture",
              "binding_name_override": "#texture",
              "binding_type": "collection",
              "binding_collection_name": "form_buttons"
            },
            {
              "binding_name": "#form_button_texture_file_system",
              "binding_name_override": "#texture_file_system",
              "binding_type": "collection",
              "binding_collection_name": "form_buttons"
            }
          ]
        }
      },
      {
        "button_text": {
            "type": "label",
            "text": "#form_button_text",
            "layer": 10,
            "font_scale_factor": 1.2,
            "offset": [0,-9],
            "anchor_from": "bottom_middle",
            "anchor_to": "bottom_middle",
            "bindings": [
              {
                  "binding_name": "#form_button_text",
                  "binding_collection_name": "form_buttons",
                  "binding_type": "collection"
              }
            ]
        }
      }
    ]
  },

    "grid_scroll_panel": {
        "type": "grid",
        "size": [325, "100%c"],
        "anchor_from": "top_middle",
        "anchor_to": "top_middle",
        "grid_item_template": "grid_buttons",
        "grid_rescaling_type": "horizontal",
        "layer": 50,
        "collection_name": "form_buttons",
        "bindings": [
            {
                "binding_name": "#form_button_length",
                "binding_name_override": "#maximum_grid_items"
            },
            {
                "binding_type": "collection",
                "binding_collection_name": "form_buttons",
                "binding_name": "#form_button_text"
            }
        ]
    },

    "grid_buttons": {
        "type": "panel",
        "size": [100, 90],
        "layer": 2,
        "controls": [
            {
                "select_buttons@select_buttons": {}
            }
        ],
        "bindings": [
            {
                "binding_type": "collection",
                "binding_collection_name": "form_buttons",
                "binding_name": "#form_button_text"
            }
        ]
    },

    "select_buttons": {
        "type": "panel",
        "size": ["100% - 4px", "100% - 4px"],
        "controls": [
            {
                "button@common.button": {
                    "$pressed_button_name": "button.form_button_click",
                    "controls": [
                        {
                            "default@bd_main.button_parts": {
                                "$texture": "textures/bd/btnc_default"
                            }
                        },
                        {
                            "hover@bd_main.button_parts_hover": {
                                "$texture": "textures/bd/btnc_pressed",
                                "$offset": [0, 0]
                            }
                        }
                    ],
                    "bindings": [
                        {
                            "binding_type": "collection_details",
                            "binding_collection_name": "form_buttons"
                        }
                    ]
                }
            }
        ]
    },

   "close_btn": {
        "type": "button",
        "size": [ 12, 12 ],
        "anchor_from": "bottom_right",
        "anchor_to": "bottom_right",
        "offset": [0,-2],
        "controls": [
           {
            "default@tipvis": {}
           },
                {
                "hover@tipvis": {}
            },
                {
                "pressed@tipvis": {}
            }
        ],
        "default_control": "default",
        "hover_control": "hover",
        "pressed_control": "pressed",
        "sound_name": "random.click",
        "sound_volume": 1,
        "sound_pitch": 1,
        "focus_enabled": true,
        "focus_wrap_enabled": false,
        "button_mappings": [
            {
                "from_button_id": "button.menu_select",
                "to_button_id": "button.menu_exit",
                "mapping_type": "pressed"
            },
            {
                "from_button_id": "button.menu_ok",
                "to_button_id": "button.menu_exit",
                "mapping_type": "focused"
            }
        ]
    },

    "tipvis": {
        "type": "image",
        "texture": "textures/ui/hud_tip_text_background",
        "size": ["100%", "100%"],
        "alpha": 0.6,
        "layer": -1,
        "controls": [
            {
                "icon": {
                    "type": "image",
                    "texture": "$icon",
                    "$icon|default": "textures/ui/close_button_default_light",
                    "size": ["80%", "80%"],
                    "layer": 1
                }
            }
        ]
    },
    "simple_scroll_panel": {
        "type": "panel",
        "size": ["100%", "100%"],
        "controls": [
            {
                "scrolling_panel@common.scrolling_panel": {
                    "$scroll_bar_contained": false,
                    "offset": [0, 0],
                    "size": [347, 195],
                    "$scrolling_content": "bd_main.simple_grid_scroll_panel",
                    "$show_background": false,
                    "$scrolling_pane_size": ["100%", "100%"],
                    "$scrolling_pane_offset": [0, 0],
                    "$bindings": [
                        {
                            "binding_type": "collection",
                            "binding_collection_name": "form_buttons",
                            "binding_name": "#form_button_text"
                        }
                    ]
                }
            }
        ]
    },

    "simple_grid_scroll_panel": {
    "type": "grid",
    "size": [347, "100%c"],
    "anchor_from": "top_middle",
    "anchor_to": "top_middle",
    "grid_item_template": "bd_main.simple_grid_buttons",
    "grid_rescaling_type": "horizontal",
    "layer": 50,
    "collection_name": "form_buttons",
    "bindings": [
      {
        "binding_name": "#form_button_length",
        "binding_name_override": "#maximum_grid_items"
      },
      {
        "binding_type": "collection",
        "binding_collection_name": "form_buttons",
        "binding_name": "#form_button_text"
      },
      {
        "binding_type": "view",
        "source_property_name": "((#form_button_text - '§a§a') = #form_button_text)",
        "target_property_name": "#visible"
      }
    ]
  },

  "simple_grid_buttons": {
    "type": "panel",
    "size": [110, 90],
    "layer": 2,
            "controls": [
            {
                "simple_select_buttons@bd_main.simple_select_buttons": {}
            }
        ],
    "bindings": [
      {
        "binding_type": "collection",
        "binding_collection_name": "form_buttons",
        "binding_name": "#form_button_text"
      },
      {
        "binding_type": "view",
        "source_property_name": "(not ((#form_button_text - '§r') = #form_button_text))",
        "target_property_name": "#visible"
      }
    ]
  },

    "simple_select_buttons": {
        "type": "panel",
        "size": ["100% - 4px", "100% - 4px"],
        "controls": [
            {
                "button@common.button": {
                    "$pressed_button_name": "button.form_button_click",
                    "controls": [
                        {
                            "default@bd_main.button_parts": {
                                "$texture": "textures/bd/btnc_default"
                            }
                        },
                        {
                            "hover@bd_main.button_parts_hover": {
                                "$texture": "textures/bd/btnc_pressed",
                                "$offset": [0, 0]
                            }
                        }
                    ],
                    "bindings": [
                        {
                            "binding_type": "collection_details",
                            "binding_collection_name": "form_buttons"
                        }
                    ]
                }
            }
        ]
    }
}