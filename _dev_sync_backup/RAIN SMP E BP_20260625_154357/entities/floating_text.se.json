{
    "format_version": "1.26.0",
    "minecraft:entity": {
        "description": {
            "identifier": "ae_sg:floating_text",
            "is_spawnable": false,
            "is_summonable": true
        },
        "component_groups": {
            "ae_sg:despawn": {
                "minecraft:instant_despawn": {}
            }
        },
        "components": {
            "minecraft:nameable": {
                "allow_name_tag_renaming": false,
                "always_show": true
            },
            "minecraft:collision_box": {
                "height": 0.1,
                "width": 0.1
            },
            "minecraft:knockback_resistance": {
                "value": 1,
                "max": 1
            },
            "minecraft:buoyant": {
                "base_buoyancy": 0,
                "apply_gravity": false,
                "simulate_waves": false,
                "liquid_blocks": ["water"]
            },
            "minecraft:custom_hit_test": {
                "hitboxes": [
                    {
                        "width": 1,
                        "height": 1,
                        "pivot": [
                            0,
                            9999,
                            0
                        ]
                    }
                ]
            },
            "minecraft:timer": {
                "time": 0.05,
                "looping": true,
                "time_down_event": {
                    "event": "ae_sg:tick",
                    "target": "self"
                }
            }
        },
        "events": {
            "ae_sg:despawn": {
                "add": {
                    "component_groups": [
                        "ae_sg:despawn"
                    ]
                }
            },
            "ae_sg:tick": {
                "queue_command": {
                    "command": ["tp @s ~ ~ ~"]
                }
            }
        }
    }
}