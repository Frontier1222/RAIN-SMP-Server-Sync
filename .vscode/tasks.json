{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Deploy manifests to PebbleHost",
            "type": "shell",
            "command": "npm run deploy:manifests",
            "options": {
                "cwd": "${workspaceFolder}/.vscode"
            },
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "focus": true
            },
            "problemMatcher": []
        },
        {
            "label": "Deploy RAIN SMP packs to PebbleHost",
            "type": "shell",
            "command": "npm run deploy:rain",
            "options": {
                "cwd": "${workspaceFolder}/.vscode"
            },
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "focus": true
            },
            "problemMatcher": []
        },
        {
            "label": "Download server packs (PowerShell)",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}/.vscode/download.ps1"
            ],
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "focus": true
            },
            "problemMatcher": []
        }
    ]
}
