{
	"format_version": "1.20.70",
	"minecraft:entity": {
		"description": {
			"identifier": "ulkd_ess:sleeping_bag",
			"is_spawnable": false,
			"is_summonable": true,
			"animations": {
				"sleeping": "controller.animation.ulkd_ess.sleeping_bag"
			},
			"scripts": {
				"animate": [
					"sleeping"
				]
			},
			"properties": {
				"ulkd_ess:in_overworld": {
					"type": "bool",
					"default": true
				}
			}
		},
		"component_groups": {
			"instant_despawn": {
				"minecraft:instant_despawn": {}
			},
			"delayed_despawn": {
				"minecraft:timer": {
					"time": 0.05,
					"looping": false,
					"time_down_event": {
						"event": "instant_despawn",
						"target": "self"
					}
				}
			},
			"explode": {
				"minecraft:explode": {
					"breaks_blocks": true,
					"causes_fire": false,
					"fuse_lit": true,
					"power": 1,
					"fuse_length": 0
				}
			}
		},
		"components": {
			"minecraft:environment_sensor": {
				"triggers": [
					{
						"event": "in_overworld",
						"target": "self",
						"filters": {
							"all_of": [
								{
									"test": "bool_property",
									"operator": "==",
									"value": false,
									"domain": "ulkd_ess:in_overworld"
								},
								{
									"test": "has_biome_tag",
									"operator": "==",
									"value": "overworld"
								}
							]
						}
					},
					{
						"event": "not_in_overworld",
						"target": "self",
						"filters": {
							"all_of": [
								{
									"test": "bool_property",
									"operator": "==",
									"value": true,
									"domain": "ulkd_ess:in_overworld"
								},
								{
									"test": "has_biome_tag",
									"operator": "!=",
									"value": "overworld"
								}
							]
						}
					}
				]
			},
			"minecraft:collision_box": {
				"width": 1,
				"height": 0.1
			},
			"minecraft:health": {
				"value": 0.5,
				"max": 0.5
			},
			"minecraft:loot": {
				"table": "loot_tables/ulkd/sleeping_bag.lt.json"
			},
			"minecraft:rideable": {
				"controlling_seat": 0,
				"crouching_skip_interact": true,
				"family_types": [
					"player"
				],
				"interact_text": "",
				"pull_in_entities": false,
				"rider_can_interact": false,
				"seat_count": 1,
				"seats": [
					{
						"position": [
							0,
							0,
							0
						],
						"max_rider_count": 1,
						"lock_rider_rotation": 0
					}
				]
			},
			"minecraft:persistent": {},
			"minecraft:physics": {},
			"minecraft:fire_immune": {},
			"minecraft:nameable": {
				"allow_name_tag_renaming": true,
				"always_show": false
			},
			"minecraft:damage_sensor": {
				"triggers": [
					{
						"cause": "entity_attack",
						"deals_damage": false,
						"on_damage": {
							"filters": {
								"test": "is_family",
								"subject": "other",
								"value": "player"
							},
							"event": "destroy"
						}
					},
					{
						"cause": "all",
						"deals_damage": false
					}
				]
			},
			"minecraft:knockback_resistance": {
				"value": 1,
				"max": 1
			},
			"minecraft:buoyant": {
				"liquid_blocks": [
					"minecraft:water",
					"minecraft:flowing_water",
					"minecraft:lava",
					"minecraft:flowing_lava"
				]
			},
			"minecraft:type_family": {
				"family": [
					"ess_sleeping_bag",
					"inanimate"
				]
			}
		},
		"events": {
			"instant_despawn": {
				"add": {
					"component_groups": [
						"instant_despawn"
					]
				}
			},
			"destroy": {
				"add": {
					"component_groups": [
						"delayed_despawn"
					]
				},
				"queue_command": {
					"command": "loot spawn ~~~ loot \"ulkd/sleeping_bag.lt\""
				}
			},
			"in_overworld": {
				"set_property": {
					"ulkd_ess:in_overworld": true
				}
			},
			"not_in_overworld": {
				"set_property": {
					"ulkd_ess:in_overworld": false
				}
			},
			"explode": {
				"add": {
					"component_groups": [
						"explode"
					]
				}
			}
		}
	}
}