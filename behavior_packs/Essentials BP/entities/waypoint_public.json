{
	"format_version": "1.21.70",
	"minecraft:entity": {
		"description": {
			"identifier": "ulkd_ess:waypoint_public",
			"is_spawnable": false,
			"is_summonable": true,
			"animations": {
				"update": "controller.animation.ulkd_ess.waypoint.update"
			},
			"scripts": {
				"animate": ["update"]
			}
		},
		"component_groups": {
			"instant_despawn": {
				"minecraft:instant_despawn": {}
			}
		},
		"components": {
			"minecraft:collision_box": {
				"width": 1,
				"height": 1
			},
			"minecraft:health": {
				"value": 0.5,
				"max": 0.5
			},
			"minecraft:persistent": {},
			"minecraft:physics": {},
			"minecraft:fire_immune": {},
            "minecraft:conditional_bandwidth_optimization": {},
			"minecraft:inventory": {
				"inventory_size": 54,
				"container_type": "inventory",
				"restrict_to_owner": false
			},
			"minecraft:nameable": {
				"allow_name_tag_renaming": true,
				"always_show": false
			},
			"minecraft:damage_sensor": {
				"triggers": [
					{
						"cause": "entity_attack",
						"deals_damage": "no",
						"on_damage": {
							"filters": {
								"test": "is_family",
								"subject": "other",
								"value": "player"
							}
						}
					},
					{
						"cause": "all",
						"deals_damage": "no"
					}
				]
			},
			"minecraft:knockback_resistance": {
				"value": 1,
				"max": 1
			},
			"minecraft:buoyant": {
				"liquid_blocks": [
					"minecraft:water",
					"minecraft:flowing_water",
					"minecraft:lava",
					"minecraft:flowing_lava"
				]
			},
			"minecraft:type_family": {
				"family": [
					"ess_waypoint",
					"inanimate"
				]
			}
		},
		"events": {
			"instant_despawn": {
				"add": {
					"component_groups": [
						"instant_despawn"
					]
				}
			},
			"minecraft:entity_spawned": {
				"queue_command": {
					"command": "tp @e[type=item,r=5] ~ ~0.2 ~"
				}
			}
		}
	}
}