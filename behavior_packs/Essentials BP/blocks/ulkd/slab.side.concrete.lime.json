{
  "format_version": "1.21.60",
  "minecraft:block": {
    "description": {
      "identifier": "ulkd_ess:slab.side.concrete.lime",
      "traits": {
        "minecraft:placement_direction": {
          "enabled_states": [
            "minecraft:facing_direction"
          ],
          "y_rotation_offset": 180
