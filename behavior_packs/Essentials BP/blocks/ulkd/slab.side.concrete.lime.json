            "rotation": [
              0,
              90,
              180
            ]
          },
          "minecraft:liquid_detection": {
            "detection_rules": [
              {
                "can_contain_liquid": true,
                "on_liquid_touches": "no_reaction",
                "stops_liquid_flowing_from_direction": [
