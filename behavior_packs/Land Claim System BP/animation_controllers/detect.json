{
    "format_version": "1.26.0",
    "animation_controllers": {
        "controller.animation.detect.attack": {
            "states": {
                "default": {
                    "transitions": [
                        {
                            "attacking": "variable.attack_time"
                        }
                    ]
                },
                "attacking": {
                    "on_entry": ["@s attack_start"],
                    "transitions": [
                        {
                            "default": "!variable.attack_time"
                        }
                    ]
                }
            }
        }
    }
}