{
  "format_version": "1.20.10",
  "minecraft:entity": {
    "description": {
      "identifier": "ftb_tc:modifier_worktable",
      "is_summonable": true,
      "is_spawnable": false,
      "scripts": {
        "animate": ["modifier"]
      },
      "animations": {
        "modifier": "controller.animation.ftb_tc.modifier.use"
      },
      "properties": {
        "ftb_tc:used_modifier": {
          "type": "bool",
          "default": false,
          "client_sync": true
        },
        "ftb_tc:has_tool": {
          "type": "bool",
          "default": false,
          "client_sync": true
        }
      }
    },
    "component_groups": {
      "ftb_tc:ticking": {
        "minecraft:timer": {
          "time": 0.01,
          "looping": true,
          "time_down_event": {
            "event": "ftb_tc:remove_effects",
            "target": "self"
          }
        }
      },
      "ftb_tc:remove_effects": {
        "minecraft:spell_effects": {
          "remove_effects": ["levitation", "slowness", "slow_falling"]
        }
      },
      "ftb_tc:remove_check": {
        "minecraft:is_baby": {}
      },
      "ftb_tc:remove": {
        "minecraft:is_chested": {},
        "minecraft:instant_despawn": {}
      },
      "ftb_tc:drop_held_item": {
        "minecraft:transformation": {
          "into": "ftb_tc:modifier_drop_entity",
          "delay": {
            "value": 0.1
          },
          "drop_inventory": true,
          "drop_equipment": true
        }
      },
      "ftb_tc:empty": {
        "minecraft:interact": {
          "interactions": [
            {
              "on_interact": {
                "event": "ftb_tc:add_tool"
              },
              "interact_text": "Add Tool"
            }
          ]
        }
      },
      "ftb_tc:has_tool": {
        "minecraft:interact": {
          "interactions": [
            
            {
              "on_interact": {
                "filters": {
                  "all_of": [
                    {
                      "test": "is_family",
                      "subject": "other",
                      "value": "player"
                    },
                    {
                      "test": "is_sneak_held",
                      "subject": "other",
                      "value": false
                    }
                  ],
                  "any_of": [
                    {
                      "test": "has_equipment",
                      "value": "ftb_tc:armadillo_modifier",
                      "domain": "hand",
                      "operator": "equals",
                      "subject": "player"
                    },
                    {
                      "test": "has_equipment",
                      "value": "ftb_tc:emerald_modifier",
                      "domain": "hand",
                      "operator": "equals",
                      "subject": "player"
                    },
                    {
                      "test": "has_equipment",
                      "value": "ftb_tc:ender_modifier",
                      "domain": "hand",
                      "operator": "equals",
                      "subject": "player"
                    },
                    {
                      "test": "has_equipment",
                      "value": "ftb_tc:glowstone_modifier",
                      "domain": "hand",
                      "operator": "equals",
                      "subject": "player"
                    },
                    {
                      "test": "has_equipment",
                      "value": "ftb_tc:lapis_modifier",
                      "domain": "hand",
                      "operator": "equals",
                      "subject": "player"
                    },
                    {
                      "test": "has_equipment",
                      "value": "ftb_tc:lightning_modifier",
                      "domain": "hand",
                      "operator": "equals",
                      "subject": "player"
                    },
                    {
                      "test": "has_equipment",
                      "value": "ftb_tc:necrotic_modifier",
                      "domain": "hand",
                      "operator": "equals",
                      "subject": "player"
                    },
                    {
                      "test": "has_equipment",
                      "value": "ftb_tc:netherstar_modifier",
                      "domain": "hand",
                      "operator": "equals",
                      "subject": "player"
                    },
                    {
                      "test": "has_equipment",
                      "value": "ftb_tc:obsidian_modifier",
                      "domain": "hand",
                      "operator": "equals",
                      "subject": "player"
                    },
                    {
                      "test": "has_equipment",
                      "value": "ftb_tc:piston_modifier",
                      "domain": "hand",
                      "operator": "equals",
                      "subject": "player"
                    },
                    {
                      "test": "has_equipment",
                      "value": "ftb_tc:prismarine_modifier",
                      "domain": "hand",
                      "operator": "equals",
                      "subject": "player"
                    },
                    {
                      "test": "has_equipment",
                      "value": "ftb_tc:quartz_modifier",
                      "domain": "hand",
                      "operator": "equals",
                      "subject": "player"
                    },
                    {
                      "test": "has_equipment",
                      "value": "ftb_tc:redstone_modifier",
                      "domain": "hand",
                      "operator": "equals",
                      "subject": "player"
                    },
                    {
                      "test": "has_equipment",
                      "value": "ftb_tc:remove_modifier",
                      "domain": "hand",
                      "operator": "equals",
                      "subject": "player"
                    },
                    {
                      "test": "has_equipment",
                      "value": "ftb_tc:rotten_modifier",
                      "domain": "hand",
                      "operator": "equals",
                      "subject": "player"
                    },
                    {
                      "test": "has_equipment",
                      "value": "ftb_tc:scute_modifier",
                      "domain": "hand",
                      "operator": "equals",
                      "subject": "player"
                    },
                    {
                      "test": "has_equipment",
                      "value": "ftb_tc:shulker_modifier",
                      "domain": "hand",
                      "operator": "equals",
                      "subject": "player"
                    },
                    {
                      "test": "has_equipment",
                      "value": "ftb_tc:silky_modifier",
                      "domain": "hand",
                      "operator": "equals",
                      "subject": "player"
                    },
                    {
                      "test": "has_equipment",
                      "value": "ftb_tc:spider_modifier",
                      "domain": "hand",
                      "operator": "equals",
                      "subject": "player"
                    },
                    {
                      "test": "has_equipment",
                      "value": "ftb_tc:tnt_modifier",
                      "domain": "hand",
                      "operator": "equals",
                      "subject": "player"
                    },
                    {
                      "test": "has_equipment",
                      "value": "ftb_tc:totem_modifier",
                      "domain": "hand",
                      "operator": "equals",
                      "subject": "player"
                    }
                  ]
                },
                "event": "ftb_tc:modifier"
              },
              "interact_text": "Add Modifier"
            },
            {
              "on_interact": {
                "event": "ftb_tc:remove_tool"
              },
              "interact_text": "Remove Tool"
            }
          ]
        }
      }
    },
    "components": {
      "minecraft:scale": {
        "value": 0.75
      },
      "minecraft:inventory": {
        "can_be_siphoned_from": false,
        "container_type": "inventory",
        "inventory_size": 1,
        "private": true,
        "restrict_to_owner": false
      },
      "minecraft:collision_box": {
        "width": 0.0,
        "height": 0.0
      },
      "minecraft:health": {
        "value": 1,
        "max": 1
      },
      "minecraft:custom_hit_test": {
        "hitboxes": [
          {
            "width": 0,
            "height": 0,
            "pivot": [0, 0, 0]
          }
        ]
      },
      "minecraft:damage_sensor": {
        "triggers": [
          {
            "cause": "all",
            "deals_damage": false
          }
        ]
      },
      "minecraft:is_stackable": {},
      "minecraft:knockback_resistance": {
        "value": 1,
        "max": 1
      },
      "minecraft:push_through": 1,
      "minecraft:navigation.swim": {
        "can_sink": true
      },
      "minecraft:movement": {
        "value": 0,
        "max": 0
      },
      "minecraft:movement.basic": {
        "max_turn": 0
      },
      "minecraft:underwater_movement": {
        "value": 0
      },
      "minecraft:water_movement": {
        "drag_factor": 0
      },
      "minecraft:equip_item": {
      },
      "minecraft:equippable": {
      }
    },
    "events": {
      "ftb_tc:drop_held_item": {
        "add": {
          "component_groups": ["ftb_tc:drop_held_item"]
        }
      },
      "ftb_tc:remove": {
        "add": {
          "component_groups": ["ftb_tc:remove"]
        },
        "set_property": {
          "ftb_tc:is_solid": false
        }
      },
      "ftb_tc:remove_check": {
        "sequence": [
          {
            "remove": {
              "component_groups": []
            },
            "add": {
              "component_groups": ["ftb_tc:remove_check"]
            }
          }
        ]
      },
      "ftb_tc:remove_check_clear": {
        "remove": {
          "component_groups": ["ftb_tc:remove_check"]
        },
        "set_property": {
          "ftb_tc:is_solid": true
        }
      },
      "minecraft:entity_spawned": {
        "add": {
          "component_groups": ["ftb_tc:ticking", "ftb_tc:empty"]
        }
      },
      "ftb_tc:reset": {
        "remove": {
          "component_groups": ["ftb_tc:remove_check"]
        }
      },
      "ftb_tc:modifier": {
        "set_property": {
          "ftb_tc:used_modifier": true
        }
      },
      "ftb_tc:remove_modifier": {
        "set_property": {
          "ftb_tc:used_modifier": false
        }
      },
      "ftb_tc:add_tool": {
        "set_property": {
          "ftb_tc:has_tool": true
        },
        "remove": {
          "component_groups": [
            "ftb_tc:empty"
          ]
        },
        "add": {
          "component_groups": [
            "ftb_tc:has_tool"
          ]
        }
      },
      "ftb_tc:remove_tool": {
        "set_property": {
          "ftb_tc:has_tool": false
        },
        "remove": {
          "component_groups": [
            "ftb_tc:has_tool"
          ]
        },
        "add": {
          "component_groups": [
            "ftb_tc:empty"
          ]
        }
      }
    }
  }
}
