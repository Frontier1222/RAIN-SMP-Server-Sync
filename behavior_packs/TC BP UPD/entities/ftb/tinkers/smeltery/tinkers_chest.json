{
  "format_version": "1.20.10",
  "minecraft:entity": {
    "description": {
      "identifier": "ftb_tc:chest_entity",
      "is_summonable": true,
      "is_spawnable": false
    },
    "component_groups": {
      "ftb_tc:ticking": {
        "minecraft:timer": {
          "time": 0.01,
          "looping": true,
          "time_down_event": {
            "event": "ftb_tc:remove_effects",
            "target": "self"
          }
        }
      },
      "ftb_tc:remove_effects": {
        "minecraft:spell_effects": {
          "remove_effects": ["levitation", "slowness", "slow_falling"]
        }
      },
      "ftb_tc:remove_check": {
        "minecraft:is_baby": {}
      },
      "ftb_tc:remove": {
        "minecraft:is_chested": {},
        "minecraft:instant_despawn": {}
      },
      "ftb_tc:drop_held_item": {
        "minecraft:transformation": {
          "into": "ftb_tc:modifier_drop_entity",
          "delay": {
            "value": 0.1
          },
          "drop_inventory": true,
          "drop_equipment": true
        }
      }
    },
    "components": {
      "minecraft:inventory": {
        "can_be_siphoned_from": false,
        "container_type": "inventory",
        "inventory_size": 27,
        "private": false,
        "restrict_to_owner": false
      },
      "minecraft:collision_box": {
        "width": 0.0,
        "height": 0.0
      },
      "minecraft:health": {
        "value": 1,
        "max": 1
      },
      "minecraft:custom_hit_test": {
        "hitboxes": [
          {
            "width": 0.7,
            "height": 0.7,
            "pivot": [0, 0.55, 0.2]
          },
          {
            "width": 0.7,
            "height": 0.7,
            "pivot": [0, 0.55, -0.2]
          },
          {
            "width": 0.7,
            "height": 0.7,
            "pivot": [0.2, 0.55, 0]
          },
          {
            "width": 0.7,
            "height": 0.7,
            "pivot": [-0.2, 0.55, 0]
          }
        ]
      },
      "minecraft:damage_sensor": {
        "triggers": [
          {
            "cause": "all",
            "deals_damage": false
          }
        ]
      },
      "minecraft:is_stackable": {},
      "minecraft:knockback_resistance": {
        "value": 1,
        "max": 1
      },
      "minecraft:push_through": 1,
      "minecraft:navigation.swim": {
        "can_sink": true
      },
      "minecraft:movement": {
        "value": 0,
        "max": 0
      },
      "minecraft:movement.basic": {
        "max_turn": 0
      },
      "minecraft:underwater_movement": {
        "value": 0
      },
      "minecraft:water_movement": {
        "drag_factor": 0
      },
      "minecraft:equip_item": {},
      "minecraft:equippable": {}
    },
    "events": {
      "ftb_tc:drop_held_item": {
        "add": {
          "component_groups": ["ftb_tc:drop_held_item"]
        }
      },
      "ftb_tc:remove": {
        "add": {
          "component_groups": ["ftb_tc:remove"]
        },
        "set_property": {
          "ftb_tc:is_solid": false
        }
      },
      "ftb_tc:remove_check": {
        "sequence": [
          {
            "remove": {
              "component_groups": []
            },
            "add": {
              "component_groups": ["ftb_tc:remove_check"]
            }
          }
        ]
      },
      "ftb_tc:remove_check_clear": {
        "remove": {
          "component_groups": ["ftb_tc:remove_check"]
        },
        "set_property": {
          "ftb_tc:is_solid": true
        }
      },
      "minecraft:entity_spawned": {
        "add": {
          "component_groups": ["ftb_tc:ticking"]
        }
      },
      "ftb_tc:reset": {
        "remove": {
          "component_groups": ["ftb_tc:remove_check"]
        }
      }
    }
  }
}
