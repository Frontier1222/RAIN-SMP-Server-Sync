{
	"format_version": "1.10.0",
	"animation_controllers": {
		"controller.animation.ftb_tc.casting_table_particles": {
			"initial_state": "default",
			"states": {
				"default": {
					"transitions": [
						{
							"particles": "query.is_saddled"
						}
					]
				},
				"particles": {
					"transitions": [
						{
							"default": "!query.is_saddled"
						}
					],
					"animations": [
						"particles"
					]
				}
			}
		}
	}
}