{
	"format_version": "1.10.0",
	"animation_controllers": {
		"controller.animation.ftb_tc.casting_table": {
			"initial_state": "default",
			"states": {
				"default": {
					"transitions": [
						{
							"lit": "query.is_saddled"
						}
					],
					"on_entry": [
						"/setblock ~ ~ ~ ftb_tc:barrier_block"
					]
				},
				"lit": {
					"transitions": [
						{
							"default": "!query.is_saddled"
						}
					],
					"on_entry": [
						"/execute at @s run function ftb/tinkers/light_block" 
					]
				}
			}
		}
	}
}